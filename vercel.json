{
  "rewrites": [
    { "source": "/api/job-offer/:id",    "destination": "/api/job-offer?id=:id" },
    { "source": "/api/job/:id",          "destination": "/api/job?id=:id" },
    { "source": "/api/admin-job/:id",    "destination": "/api/admin-job?id=:id" },
    { "source": "/api/admin-driver/:id", "destination": "/api/admin-driver?id=:id" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ]
}
