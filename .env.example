# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Driver auth
DRIVER_TOKEN_SECRET=at-least-32-chars-random-secret-here

# Internal API calls (webhook → notify)
INTERNAL_SECRET=another-random-secret

# Joe's driver ID (from Supabase drivers table after inserting Joe)
JOE_DRIVER_ID=joe-uuid-from-supabase

# Email (Resend)
RESEND_API_KEY=re_xxxx
NOTIFY_FROM_EMAIL=jobs@yourdomain.co.uk

# App URL (set on Vercel automatically, override locally)
NEXT_PUBLIC_BASE_URL=http://localhost:5173
