# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Driver auth
DRIVER_TOKEN_SECRET=at-least-32-chars-random-secret-here

# Internal API calls (webhook → notify)
INTERNAL_SECRET=another-random-secret

# Joe's driver ID (from Supabase drivers table after inserting Joe)
JOE_DRIVER_ID=joe-uuid-from-supabase

# Email (Resend)
RESEND_API_KEY=re_xxxx
NOTIFY_FROM_EMAIL=jobs@yourdomain.co.uk

# App URL (set on Vercel automatically, override locally)
NEXT_PUBLIC_BASE_URL=http://localhost:5173

# CORS — allowed origin for API requests from the APK.
# Set to your Vercel deployment URL on production.
# CORS_ORIGIN=https://uber-van.vercel.app

# API base URL — leave blank for web (same-origin).
# Set to your Vercel URL for Capacitor APK builds.
# VITE_API_BASE_URL=https://uber-van.vercel.app

# App origin for shareable links (invite URLs, etc.).
# Only needed in Capacitor — on web, defaults to window.location.origin.
# VITE_APP_ORIGIN=https://uber-van.vercel.app

# Firebase Cloud Messaging (push notifications)
# JSON string of service account key from Firebase Console
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# APK download URL (shown on driver onboarding page)
# VITE_APK_URL=https://your-host.com/uber-van.apk
